# ─── .env.example ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Multi-Tenant Financial Reporting Platform"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/fintech_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO_SQL=false

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: anthropic | openai
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# Model names (change if you want to pin a specific version)
LLM_MODEL_ANTHROPIC=claude-sonnet-4-6
LLM_MODEL_OPENAI=gpt-4o
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.0
LLM_REQUEST_TIMEOUT=60

# ── Currency Exchange Rates ───────────────────────────────────────────────────
# 1 USD = N <currency> (decimal strings — no floats)
BASE_CURRENCY=USD
EXCHANGE_RATE_USD_TO_ZWG=3586.00
EXCHANGE_RATE_USD_TO_ZAR=18.75

# ── Compliance Thresholds ─────────────────────────────────────────────────────
CTR_THRESHOLD_USD=10000.00
SAR_STRUCTURING_WINDOW_DAYS=5
SAR_STRUCTURING_TRANSACTION_COUNT=3
